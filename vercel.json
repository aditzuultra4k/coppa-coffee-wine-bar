{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...path].js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/(.*\\.(?:css|js|png|jpg|jpeg|svg|ico))",
      "dest": "/public/$1"
    },
    {
      "src": "/staff(?:\\.html)?",
      "dest": "/public/staff.html"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    }
  ]
}
